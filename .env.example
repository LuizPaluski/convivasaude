# URL pública do site (sem barra no final).
# Usada por sitemap.ts, robots.ts, layout.tsx (canonical/OpenGraph).
NEXT_PUBLIC_SITE_URL=https://convivasaude.com.br

# Número de WhatsApp para o CTA (apenas dígitos, com DDI 55).
NEXT_PUBLIC_WHATSAPP_NUMBER=5531936182994

# Webhook opcional para receber dados do formulário de contato.
# Se vazio, o formulário abre WhatsApp com mensagem pré-preenchida.
CONTACT_WEBHOOK_URL=

# Admin do blog: senha única de acesso a /admin.
ADMIN_PASSWORD=troque-esta-senha
# Segredo para assinar o cookie de sessão (string longa aleatória).
# Gere com: openssl rand -hex 32
ADMIN_SESSION_SECRET=

# Caminho opcional do banco SQLite (default: ./data/blog.db).
BLOG_DB_PATH=
